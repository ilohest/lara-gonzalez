---

import AnchorHandler from '@lara/components/anchor/AnchorHandler';
import Heading from '@lara/components/heading/Heading';
import ProjectList from '@lara/components/project/ProjectList';
import WrapperHeader from '@lara/components/wrapper/HeaderWrapper';
import Layout from '@lara/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const proyectos = await getCollection('proyectos');
const { title, anchors, projectsList } = proyectos[0].data; 

---

<Layout title="Proyectos | Lara González" description="">
	<WrapperHeader client:load />
	<section class="projects wrapper-fluid">
		<div class="projects__heading">
			<Heading tag="h1" size="xxl">
			{title}
			</Heading>
		</div>
		<div class="projects__list">
			{anchors.map((anchor) => (
			<a
				class="button--link"
				href={`#${anchor.toLowerCase().replace(/\s+/g, "-")}`}
				data-anchor={anchor.toLowerCase().replace(/\s+/g, "-")}
			>
				{anchor}
			</a>
			))}
		</div>
		<AnchorHandler client:load />
		<ProjectList projectsList={projectsList} />
	</section>
</Layout>

  <style lang="scss">
	@use "dawuti" as *;
  
	.projects {
		
	  &__heading {
		display: flex;
		gap: var(--s6);
		padding: var(--s10) 0;
	  }

	  &__list{
		display: flex;
		gap: var(--s8);

		a{
			@include f('sec-base', 400, true);
			color: var(--color-grey);
		}

	  }

	  &__image-slider {
		margin-top: calc(var(--s) * 10);
		.swiper {
		  &-navigation {
			margin-top: calc(var(--s) * 4);
			margin-right: calc(var(--s) * 4);
			display: flex;
			justify-content: flex-end;
			column-gap: calc(var(--s) * 3);
			&--prev,
			&--next {
			  cursor: pointer;
			  display: inline-block;
			  svg,
			  path {
				transition: fill 0.2s linear;
			  }
  
			  &:active,
			  &:hover,
			  &:focus-visible {
				outline: none;
				svg {
				  background-color: var(--color-light);
				  border-radius: 100%;
				  padding: 1px;
				}
				svg path {
				  fill: var(--color-text);
				}
			  }
			}
		  }
  
		  &-wrapper {
			.swiper-slide {
			  height: auto;
			  width: auto;
			  :global(.image img) {
				height: 500px;
				width: auto;
				@include mq-lg {
				  height: 570px;
				}
			  }
			}
		  }
		}
	  }
	}
  </style>


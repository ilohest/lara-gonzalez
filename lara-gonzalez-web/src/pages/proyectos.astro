---

import AnchorHandler from '@lara/components/anchor/AnchorHandler';
import Heading from '@lara/components/heading/Heading';
import ProjectItem from '@lara/components/project/ProjectItem';
import WrapperHeader from '@lara/components/wrapper/HeaderWrapper';
import Layout from '@lara/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const proyectos = await getCollection('proyectos');
const { title, anchors, projectitem } = proyectos[0].data; 

---

<Layout title="Proyectos | Lara González" description="">
	<WrapperHeader client:load />
	<section class="projects wrapper-fluid">
		<div class="projects__heading">
			<Heading tag="h1" size="xxl">
			{title}
			</Heading>
		</div>
		<div class="projects__list">
			{anchors.map((anchor) => (
			<a
				class="button button--link"
				href={`#${anchor.toLowerCase().replace(/\s+/g, "-")}`}
				data-anchor={anchor.toLowerCase().replace(/\s+/g, "-")}
			>
				{anchor}
			</a>
			))}
		</div>
		<AnchorHandler client:load />
		<ProjectItem projectitem={projectitem} client:load />
	</section>
</Layout>

  <style lang="scss">
	@use "dawuti" as *;
  
	.projects {
		@include mq-sm {
			margin-top: calc(var(--s) * 7);
		}
		@include mq-lg {
			margin-top: calc(var(--s) * 13);
		}
	  &__heading {
			display: flex;
			:global(.heading) {
				@include f('hero-title', 400, true);
			}
	  }

	  :global(.projects__header) {
			margin-top: calc(var(--s) * 3);
			margin-bottom: calc(var(--s) * 3);
			@include mq-md {
				display: flex;
				flex-wrap: wrap;
				align-items: flex-end;
				justify-content: space-between;
				padding-right: calc(size-by-cols(1, 24) + 10px);
				margin-bottom: calc(var(--s) * 4.5);
				gap: var(--s4);
			}
			:global(.heading) {
				margin-bottom: var(--s3);
				@include mq-md {
					margin-bottom: 0;
				}
			}
	  }

	  &__list{
		margin: var(--s8) 0 var(--s7);
		display: flex;
		flex-wrap: wrap;
		column-gap: var(--s5);
		row-gap: var(--s);
		@include mq-md {
			margin: var(--s10) 0 0;
		}

		a {
			cursor: pointer;
			@include f('sec-base', 400, true);
			color: var(--color-grey);
			transition: color .25s ease-in-out;
			&:hover,
			&:focus-visible {
				color: var(--color-primary);
			}

		}
	  }
	}
</style>


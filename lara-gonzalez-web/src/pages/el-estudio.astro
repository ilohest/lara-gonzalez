---
import Heading from '@lara/components/heading/Heading';
import Marquee from '@lara/components/marquee/Marquee';
import WrapperHeader from '@lara/components/wrapper/HeaderWrapper';
import Layout from '@lara/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const estudio = await getCollection('estudio');
//console.log(estudio)

const { title, gallery, quotes, marquee, footerImage, hero } = estudio[0].data; 
const { Content } = await render(estudio[0])


---
<Layout title="El estudio | Lara González" description="">
	<WrapperHeader client:load />
	<header>
		<Heading tag="h1" size="lg" className='sr-only'>
			{title}
		</Heading>
		<!-- <img src={headerImage} alt="Cabecera del estudio" /> -->
	</header>
	<article>
		<!-- Reenderiza el markdown definido en el estudio.md -->
		<Content></Content>

		<!-- TODO: NEREA -->
		<!-- <div class="studio__images">
			{gallery.map((image) => (
				<img src={image} alt="Imagen del estudio" />
			))}
		</div> -->
		<section>
			<Heading tag="h2" size="md">{quotes.heading}</Heading>
			<ul>
			{quotes.items.map((quote) => (
				<li>
					<blockquote>
						<p>"{quote}"</p>
					</blockquote>
				</li>
			))}
			</ul>
			{quotes.cta &&
				<div class="actions-wrapper actions-wrapper--center">
					<a class="button button--dark" href={quotes.cta.url}>{quotes.cta.text}</a>
				</div>
			}
		</section>
		{marquee &&
		<Marquee link={marquee.url} client:load>
			<span>{marquee.text}</span>
		</Marquee>
		}
	</article>
	<img src={footerImage} alt="Cabecera del estudio" />
</Layout>

<style lang="scss">
	@use "dawuti" as *;

	header{
		margin-top: var(--s6);
	}

	.studio{
		&__images{
			display: flex;
			justify-content: center;
			flex-wrap: wrap;
			gap: var(--s3);

			img{
				width: 280px;
				height: 350px;

			}
		}
	}


</style>


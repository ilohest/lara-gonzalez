---
import Heading from '@lara/components/Heading/Heading';
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const studio = await getCollection('el-estudio');

---

<Layout title="El estudio | Lara González" description=''>
		{		
			studio.map(s => {
				const { data } = s
				const { title, description } = data

				return (
					<article>
						<Heading tag="h1" size="lg">
							{title}
						</Heading>
						<p>{description}</p>
					</article>
				)
			})
		}
</Layout>

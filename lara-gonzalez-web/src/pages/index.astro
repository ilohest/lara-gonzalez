---
import Heading from '@lara/components/heading/Heading';
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import WrapperHeader from '@lara/components/wrapper/HeaderWrapper';
import Icon from '../components/shared/Icon';
import Card from '@lara/components/card/Card.astro';

const home = await getCollection('home');
const { hero, projectsSection, services, } = home[0].data; 
const { Content } = await render(home[0])

---

<Layout title="Lara Gonzalez estudio | Branding studio" description="Creamos marcas con personalidad porque creemos que es la única forma de hacerlo. Damos vida a ideas con diseño estratégico y creatividad logrando marcas que inspiran y dejan huella." classes="page__home">
	<WrapperHeader hero={hero} client:load />	
	<section class="home__projects wrapper-fluid">
		<div class="home__projects--content">
			<Content />
		</div>
		<div class="home__projects--images">
			<img src={projectsSection.imageLg} alt="Rebranding La Madre" />
			<img src={projectsSection.imageSm} alt="Diseño camiseta chica" />
		</div>
		<div class="actions-wrapper actions-wrapper--center">
		 	<a class="button button--solid button--regular" href={projectsSection.cta.url}>{projectsSection.cta.text}</a>
		</div>
	</section>
	
	<section class="home__services">
		{services.map((service) => (
			<>
	  
			{service.steps && service.steps.length > 0 && (
				<div class="home__services-item has-steps">
					<div class="home__services-header wrapper-fluid">
						<Heading tag="h2" size="xl" headingFontWeight={700}>{service.category}</Heading>
						<div class="home__services-button home__services-button--desktop">
							<a href={service.button.link} class={`button button--regular button--${service.button.type}`}>
								{service.button.text}
								<Icon classes="icon--arrow" url="/static-icons/arrow.svg" />
							</a>
						</div>
					</div>
					<div class="home__steps-block swiper">
						<div class="home__steps swiper-wrapper">
							{service.steps.map((step, i) => (
								<>
									<Card card={step} index={i} />
								</>
							))}
						</div>
					</div>
					<div class="home__services-button home__services-button--mobile wrapper-fluid">
						<a href={service.button.link} class={`button button--regular button--${service.button.type}`}>
							{service.button.text}
							<Icon classes="icon--arrow" url="/static-icons/arrow.svg" />
						</a>
					</div>
				</div>
			)}

			{!service.steps && (
				<div class="home__services-item no-steps">
					<div class="home__services-header">
						<Heading tag="h2" size="xl" headingFontWeight={700}>{service.category}</Heading>
					</div>
					<div class="home__services-button">
						<a href={service.button.link} class={`button button--regular button--${service.button.type}`}>
							{service.button.text}
							<Icon classes="icon--arrow" url="/static-icons/arrow.svg" />
						</a>
					</div>
				</div>
			)}
			</>
		))}
	</section>
</Layout>

<style lang="scss">
	@use "dawuti" as *;

	.home {

		&__services {
			padding-top: calc(var(--s) * 7);
			@include mq-md {
			}

			.has-steps {
				position: relative;
				.home__services-button {
					&--desktop {
						display: none;
						@include mq-xs {
							display: block;
						}
					}
					&--mobile {
						margin-top: var(--s6);
						@include mq-xs {
							display: none;
						}
					}
				}
				.home__services-header {
					padding-bottom: var(--s8);
				}
			}

			.no-steps {
				margin-right: var(--safe-area);
				margin-left: var(--safe-area);
				@include mq-xs {
					display: flex;
					justify-content: space-between;
					align-items: center;
				}
				.home__services-header {
					padding-bottom: calc(var(--s) * 6.3);
					@include mq-xs {
						padding-bottom: 0;
					}
				}
			}
			&-item {
				padding-top: var(--s9);
				padding-bottom: var(--s9);
				border-bottom: 1px solid var(--color-dark);
			}

			&-header {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				row-gap: calc(var(--s) * 6.3);
				@include mq-xs {
					flex-direction: row;
					align-items: center;
				}
			}

			.swiper {
				padding-left: var(--safe-area)!important;
				padding-right: var(--safe-area)!important;
			}

			.swiper-slide {
				height: auto;
				width: auto;
			}
		}

		&__steps {
			padding-right: var(--safe-area);
			cursor: ew-resize;
			@include mq-lg {
				cursor: none;
			}
		}

		&__projects {
			padding-top: calc(var(--s) * 13);
			padding-bottom: calc(var(--s) * 9);
			background-color: var(--color-tertiary);
			@include mq-lg {
				padding-top: calc(var(--s) * 16);
				padding-bottom: calc(var(--s) * 8);
			}

			&--content {

				@include mq-xs {
					padding-right: size-by-cols(2, 12);
				}
				@include mq-xxl {
					padding-right: size-by-cols(4, 12);
				}
				:global(p) {
					@include f('lg', 700, true);
					line-height: 1;
					@include mq-sm {
						line-height: var(--lh-lg);
					}
				}
				:global(em) {
					text-decoration: none;
					background: var(--color-primary);
					color: var(--color-primary-contrast);
				}
			}
			&--images {
				display: flex;
				flex-direction: column;
				row-gap: calc(var(--s) * 17.5);
				margin-top: calc(var(--s) * 17.5);
				margin-bottom: calc(var(--s) * 17.5);
				@include mq-xs {
					margin-top: var(--s9);
					margin-bottom: calc(var(--s) * 12);
					flex-direction: row;
					align-items: flex-end;
				}
				@include mq-sm {
					margin-top: var(--s10);
					margin-bottom: calc(var(--s) * 18);
				}
				@include mq-lg {
					margin-bottom: calc(var(--s) * 20);
				}

				img {
					width: 100%;
					height: auto;
					object-fit: contain;
					&:first-child {
						padding-right: size-by-cols(2.5, 6);
						@include mq-xs {
							width: size-by-cols(6, 12);
							padding-right: size-by-cols(1, 6);
							padding-left: size-by-cols(.5, 6);
						}
						@include mq-md {
							width: size-by-cols(11, 24);
							padding-left: size-by-cols(2, 24);
							padding-right: size-by-cols(4, 24);
						}
					}
					&:last-child {
						padding-left: size-by-cols(1, 6);
						@include mq-xs {
							width: size-by-cols(6, 12);
							padding-right: 0;
							padding-left: 0;
						}
						@include mq-md {
							width: size-by-cols(13, 24);
							padding-right: size-by-cols(2, 24);
						}
					}
				}

			}
		}
	}
</style>


<script>
  import Swiper from 'swiper';

let swipers: Swiper[] = [];

function initSwipers() {
	swipers.forEach(swiper => swiper.destroy(true, true));
	swipers = [];
	document.querySelectorAll('.home__steps-block').forEach((s) => {
	swipers.push(
		new Swiper(s as HTMLElement, {
			slidesPerView: 1.15,
			spaceBetween: 16,
			scrollbar: {
				draggable: true,
			},
			breakpoints: {
				667: {
					slidesPerView: 1.5,
				},
				768: {
					slidesPerView: 1.7,
				},
				1024: {
					slidesPerView: 2.3,
				},
				1200: {
					slidesPerView: 3,
				},
				// 1920: {
				// 	slidesPerView: 4,
				// },
			}
		})
	);
});
}

document.addEventListener('astro:after-swap', initSwipers);
document.addEventListener('DOMContentLoaded', initSwipers);


</script>

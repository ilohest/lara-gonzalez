---
import WrapperHeader from "@lara/components/wrapper/HeaderWrapper";
import Layout from "@lara/layouts/Layout.astro";
---

<Layout title="Página no encontrada | Lara González" description="Página no encontrada">
    <WrapperHeader client:load />
    <section class="error-404 error-404__wrapper wrapper-fluid">
        <p class="error-404__desc">Oh! Algo ha fallado.</p>
        <div class="actions-wrapper actions-wrapper--center">
            <a class="button button--big button--solid error-404__link" href="/">Volver</a>
        </div>
    </section>  
</Layout>
<style lang="scss">
	@use "dawuti" as *;
    .error-404 {
      height: 100%;

      &__wrapper {
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: calc(100dvh - var(--site-header));
        text-align: center;
      }

      &__desc {
        @include f('xl', 400, true);
        font-family: var(--font-secondary);
      }

      &__desc, 
      &__link {
        display: block;
      }
      &__link {
        margin-top: var(--s8);
      }
    }

</style>
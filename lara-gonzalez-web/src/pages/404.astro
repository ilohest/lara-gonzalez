---
import WrapperHeader from "@lara/components/wrapper/HeaderWrapper";
import Layout from "@lara/layouts/Layout.astro";
---

<Layout title="Página no encontrada | Lara González" description="Página no encontrada">
    <WrapperHeader client:load />
    <section class="error-404 error-404__wrapper wrapper-fluid">
        <p class="error-404__title">404</p>
        <p class="error-404__desc">Oh! Algo ha fallado.</p>
        <div class="actions-wrapper actions-wrapper--center">
            <a class="button button--big button--solid error-404__link" href="/">Volver</a>
        </div>
    </section>  
</Layout>
<style lang="scss">
	@use "dawuti" as *;
    .error-404 {
      height: 100%;

      &__wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: calc(100dvh - var(--site-header));
        margin-top: -20%;
        justify-content: center;
        @include mq-xs {
          margin-top: 0;
          justify-content: flex-start;
        }
        @include mq-sm {
          justify-content: center;
        }
        @include mq-md {
          min-height: calc(92dvh - var(--site-header));
        }
      }

      &__title {
        @include f('404', 300, true);
      }

      &__desc {
        @include f('link-lg', 400, true);
        font-family: var(--font-secondary);
        @include mq-lg {
          @include f('xl', 400, true);
          font-family: var(--font-secondary);
        }
      }

      &__desc, 
      &__link {
        display: block;
      }
      &__link {
        margin-top: var(--s5);
        @include mq-md {
          margin-top: var(--s8);
        }
      }
    }

</style>
---
import Heading from "@lara/components/heading/Heading";
import WrapperHeader from "@lara/components/wrapper/HeaderWrapper";
import Layout from "@lara/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import "../layouts/Legal.scss";

const cookies = await getCollection('cookies');

const { title } = cookies[0].data; 
const { Content } = await render(cookies[0])

---

<Layout
  title="Política de cookies | Lara González"
  description=""
>
  <section class="legal-page wrapper-fluid">
    <WrapperHeader client:load />
    <Heading tag="h1" size="lg">
      {title}
    </Heading>
    <div class="legal-content">
      <Content />
    </div>
  </section>
</Layout>

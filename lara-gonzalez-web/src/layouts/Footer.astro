---
import type { RSModel } from "@lara/models/generic.model";
import { Image } from "astro:assets";
import Icon from '../components/shared/Icon';
import { getCollection } from 'astro:content';

const shared = await getCollection('shared');
const { footerLogos } = shared[0].data; 

// const d = new Date();
// let currentYear = d.getFullYear();

const { rrss, footerClass } = Astro.props;
---

<footer class=`footer wrapper-fluid ${footerClass}`>
  <img
    class="footer__logo"
    src="/static-icons/lara-gonzalez-dark.svg"
    alt="Lara González estudio logo"
  />

  {
    rrss && (
      <section class="footer__rrss">
        <ul>
          {rrss.map((rs: RSModel) => {
            return (
              <li>
                <a class="button button--link" href={rs.url} target="_blank">
                  <span>{rs.platform}</span>
                  <Icon classes="icon--arrow" url="/static-icons/arrow.svg" />
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )
  }
  <div class="footer__content">
    <nav class="footer__legal">
      <ul>
        <li>
          <a class="button button--link button--link-footer" href="/aviso-legal">
            <span>Aviso Legal</span>
          </a>
        </li>
        <li>
          <a class="button button--link button--link-footer" href="/politica-cookies">
            <span>Política de cookies</span>
          </a>
        </li>
        <li>
          <a class="button button--link button--link-footer" href="/politica-privacidad">
            <span>Política de Privacidad</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="footer__financiacion">
      <ul>
        {footerLogos.map((logo) => (
          <li>
            <img class="footer__financiacion--logo" src={logo.url} alt={logo.alt} />
          </li>
        ))}
      </ul>
    </div>

  </div>
</footer>

<style lang="scss">
  @use "dawuti" as *;
  .footer {
    background-color: var(--color-light);
    padding-top: calc(var(--s) * 16);
    padding-bottom: var(--s7);
    background-color: var(--color-light);
    @include mq-lg {
      padding-top: calc(var(--s) * 21);
    }

    &__content {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      @include mq-xs {
        margin-top: var(--s7);
        align-items: flex-start;
        justify-content: space-between;
      }
      @include mq-sm {
        margin-top: calc(var(--s) * 10);
        column-gap: var(--s10);
      }
      @include mq-md {
        flex-direction: row-reverse;
        align-items: flex-end;
      }
      @include mq-lg {
        margin-top: calc(var(--s) * 13);
      }
    }

    &__rrss {
      @include mq-md {
        display: flex;
        justify-content: flex-end;
      }
      ul {
        display: flex;
        flex-direction: column;
        row-gap: calc(var(--s) * 2.3);
        @include mq-xs {
          column-gap: calc(var(--s) * 3.3);
          flex-direction: row;
        }
      }
      li {
        text-transform: uppercase;
        a {
          @include f('rrss', 300, true);
          display: flex;
          align-items: center;
          gap: var(--s);
        }
      }
    }

    &__financiacion {
      width: 100%;
      @include mq-xs {
        order: 1;
      }
      @include mq-sm {
        margin-bottom: calc(var(--s) * .8);
      }

      ul {
        display: flex;
        flex-wrap: wrap;
        margin-top: var(--s7);
        align-items: center;
        gap: var(--s4);
        justify-content: flex-start;
        @include mq-md {
          gap: var(--s3);
        }

        @include mq-md {
          margin-top: 0;
          flex-wrap: nowrap;
        }
      }
      li:nth-child(3) {
        img {
          max-height: var(--s6);
        }
      }

      &--logo {
        width: 100%;
        height: var(--s6);
        @include mq-md {
          height: var(--s7);
        }
        @include mq-lg {
         height: var(--s8);
        }     
      }
    }

    &__legal {
      margin-top: var(--s7);
      @include mq-xs {
        margin-top: 0;
      }
      ul {
        display: flex;
        flex-direction: column;
        @include mq-sm {
          flex-direction: row;
          align-items: center;
          column-gap: calc(var(--s) * 3);
          margin-top: calc(var(--s) * .3);
        }
      }

      li + li {
        margin-top: calc(var(--s) * 1.6);
        @include mq-sm {
          margin-top: 0;
        }
      }
      a {
        @include f('xs', 300, true);
        transition: opacity .25s ease-in-out;
        &:hover {
          opacity: .7;
        }
      }
    }
    
    &__logo {
      width: 100%;
      height: auto;
      margin-bottom: var(--s7);
      @include mq-md {
        margin-bottom: var(--s8);
      }
    }
    &-404 {
      padding-top: 0;
      @include mq-xs {
        padding-top: calc(var(--s) * 16);
      }
      @include mq-sm {
        padding-top: 0;
      }
      @include mq-lg {
        padding-top: calc(var(--s) * 16);
      }
    }
  }
</style>
